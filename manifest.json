{
  "manifest_version": 3,
  "name": "Full Page Screenshot",
  "version": "2.0.0",
  "description": "Capture the entire page as a single Ultra HD PNG screenshot",
  "permissions": [
    "activeTab",
    "debugger",
    "downloads",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
